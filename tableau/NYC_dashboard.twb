      <aliases enabled='yes' />
      <column caption='Minimum Transaction Value' datatype='integer' name='[Calculation_0817067537362944]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[price] * [minimum_nights]' />
      </column>
      <column caption='Est Monthly GMV' datatype='real' name='[Calculation_0817067537625089]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[price] * (IFNULL([revenue_proxy], 0) * 1.5)' />
      </column>
      <column caption='Market Visibility Score' datatype='real' name='[Calculation_2197367646420992]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[review_count] * ([availability_365] / 365)' />
      </column>
