  <worksheets>
    <worksheet name='Avg Market Visibility Score'>
      <table>
        <view>
          <datasources>
            <datasource caption='airbnb_nyc_cleaned' name='federated.10h7gat0t1l58t1d9c7my1nclpuh' />
          </datasources>
          <datasource-dependencies datasource='federated.10h7gat0t1l58t1d9c7my1nclpuh'>
            <column caption='Market Visibility Score' datatype='real' name='[Calculation_2197367646420992]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[review_count] * ([availability_365] / 365)' />
            </column>
            <column caption='Availability 365' datatype='integer' name='[availability_365]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_2197367646420992]' derivation='Avg' name='[avg:Calculation_2197367646420992:qk]' pivot='key' type='quantitative' />
            <column caption='Review Count' datatype='integer' name='[review_count]' role='measure' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
