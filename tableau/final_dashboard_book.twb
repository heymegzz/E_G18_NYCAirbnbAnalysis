      <aliases enabled='yes' />
      <column datatype='integer' name='[Annual Revenue Proxy]' role='measure' type='quantitative' />
      <column datatype='string' name='[Borough]' role='dimension' type='nominal' />
      <column caption='Revenue Label' datatype='string' name='[Calculation_1419671091544064]' role='measure' type='nominal'>
        <calculation class='tableau' formula='STR(ROUND(SUM([Annual Revenue Proxy])/1000000, 1)) + &quot;M&quot;' />
      </column>
      <column caption='Reviews Label' datatype='string' name='[Calculation_1419671092723713]' role='measure' type='nominal'>
        <calculation class='tableau' formula='STR(ROUND(SUM([Total Reviews])/1000, 0)) + &quot;K&quot;' />
      </column>
      <column caption='Active %' datatype='real' name='[Calculation_1419671093223426]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [Recent Activity Status] = &quot;Active (2019)&quot; THEN [Listing ID] END) / COUNTD([Listing ID])' />
      </column>
      <column caption='Summer Peak Count' datatype='integer' name='[Calculation_1419671093489667]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [Seasonality Status] = &quot;Summer Peak&quot; THEN [Listing ID] END)' />
      </column>
